{
  "name": "advocatherine.expert_v2",
  "version": "1.0.0",
  "description": "Static website",
  "main": ".eleventy.js",
  "scripts": {
    "watch:sass": "sass --watch src/assets/styles:dist/assets/styles",
    "build:sass": "sass --quiet --style=compressed src/assets/styles:dist/assets/styles",
    "watch:eleventy": "eleventy --serve",
    "build:eleventy": "NODE_ENV=production eleventy",
    "css:autoprefixer": "postcss dist/assets/styles/*.css --no-map --use autoprefixer -d dist/assets/styles",
    "start": "npm-run-all build:sass css:autoprefixer --parallel watch:*",
    "build": "npm-run-all build:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pancheliuga/advocatherine.expert_v2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Pancheliuga/advocatherine.expert_v2/issues"
  },
  "homepage": "https://github.com/Pancheliuga/advocatherine.expert_v2#readme",
  "devDependencies": {
    "@11ty/eleventy": "^1.0.2"
  },
  "dependencies": {
    "autoprefixer": "^10.4.13",
    "babel-loader": "^9.1.0",
    "fontfaceobserver": "^2.3.0",
    "html-minifier": "^4.0.0",
    "normalize.css": "^8.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.19",
    "postcss-cli": "^10.0.0",
    "sass": "^1.56.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0"
  }
}
